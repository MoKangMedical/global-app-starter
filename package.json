{
  "name": "global-app-starter",
  "version": "1.0.0",
  "description": "完整的出海项目工业化模板 - Next.js 14 + TypeScript + Stripe + 国际化",
  "keywords": [
    "nextjs",
    "typescript",
    "stripe",
    "i18n",
    "global",
    "saas",
    "internationalization",
    "payment",
    "subscription"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/global-app-starter.git"
  },
  "homepage": "https://global-app-starter.vercel.app",
  "bugs": {
    "url": "https://github.com/your-org/global-app-starter/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "i18n:extract": "formatjs extract 'src/**/*.{js,ts,tsx}' --format simple --out-file messages/en.json",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod",
    "analyze": "ANALYZE=true next build",
    "setup": "./scripts/setup.sh"
  },
  "dependencies": {
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next-intl": "^3.5.0",
    "stripe": "^14.14.0",
    "@stripe/stripe-js": "^2.4.0",
    "next-auth": "^4.24.5",
    "@sentry/nextjs": "^7.100.0",
    "posthog-js": "^1.100.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0",
    "tailwindcss": "^3.4.1",
    "clsx": "^2.1.0",
    "lucide-react": "^0.312.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "@formatjs/cli": "^6.2.12",
    "prettier": "^3.2.4",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.2.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.33",
    "autoprefixer": "^10.4.17",
    "@next/bundle-analyzer": "^14.1.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ]
}
