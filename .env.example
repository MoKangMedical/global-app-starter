# Site Configuration
NEXT_PUBLIC_SITE_URL=https://medglobal.com
NEXT_PUBLIC_SITE_NAME=MedGlobal
 
# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
 
# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret
 
# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
 
# Error Tracking
SENTRY_DSN=https://your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=https://your-public-sentry-dsn
 
# Email (Resend)
RESEND_API_KEY=re_your_key
 
# Database
DATABASE_URL=postgresql://user:password@localhost:5432/medglobal
 
# Redis (for caching)
REDIS_URL=redis://localhost:6379
 
# Medical Data Encryption (32 bytes hex)
MEDICAL_ENCRYPTION_KEY=your-64-char-hex-key-here-64-chars-long-1234567890abcdef
MEDICAL_SALT=your-medical-salt-here
 
# Compliance Settings
HIPAA_COMPLIANT=true
GDPR_COMPLIANT=true
DATA_RETENTION_DAYS=2555  # 7 years for medical records
 
# Telemedicine
VIDEO_PROVIDER=twilio  # or daily, zoom
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
 
# AI Services
OPENAI_API_KEY=sk-your-openai-key
AI_DIAGNOSTICS_ENABLED=true
 
# Pharmacy Integration
PHARMACY_API_URL=https://api.pharmacy.com
PHARMACY_API_KEY=your-pharmacy-key
 
# Insurance Verification
INSURANCE_API_URL=https://api.insurance.com
INSURANCE_API_KEY=your-insurance-key
 
# Internationalization
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,zh,ja,ko,es,fr,de,pt
 
# Medical Certifications
FDA_CLEARANCE=true
CE_MARKING=true
ISO_13485=true
